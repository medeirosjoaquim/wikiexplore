{
  "title": "WikiPulse — API Performance",
  "uid": "wikipulse-api",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "timezone": "browser",
  "refresh": "15s",
  "tags": ["wikipulse"],
  "time": { "from": "now-30m", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP request rate by path (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (path) (rate(wikipulse_http_request_duration_seconds_count{service=\"api\"}[1m]))", "legendFormat": "{{path}}" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP latency percentiles (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum by (le) (rate(wikipulse_http_request_duration_seconds_bucket{service=\"api\"}[5m])))", "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.90, sum by (le) (rate(wikipulse_http_request_duration_seconds_bucket{service=\"api\"}[5m])))", "legendFormat": "p90" },
        { "refId": "C", "expr": "histogram_quantile(0.95, sum by (le) (rate(wikipulse_http_request_duration_seconds_bucket{service=\"api\"}[5m])))", "legendFormat": "p95" },
        { "refId": "D", "expr": "histogram_quantile(0.99, sum by (le) (rate(wikipulse_http_request_duration_seconds_bucket{service=\"api\"}[5m])))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 3,
      "type": "table",
      "title": "Slowest endpoints by p95 latency",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "topk(10, histogram_quantile(0.95, sum by (le, path) (rate(wikipulse_http_request_duration_seconds_bucket{service=\"api\"}[5m]))))", "legendFormat": "{{path}}", "format": "table", "instant": true }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "API process: resident memory",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "process_resident_memory_bytes{service=\"api\"}", "legendFormat": "RSS" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "API process: CPU (cores)",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "cores" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "rate(process_cpu_seconds_total{service=\"api\"}[1m])", "legendFormat": "cpu" }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "WebSocket clients",
      "gridPos": { "h": 7, "w": 4, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "wikipulse_ws_connected_clients", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Requests (last 1h)",
      "gridPos": { "h": 7, "w": 4, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "sum(increase(wikipulse_http_request_duration_seconds_count{service=\"api\"}[1h]))", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "API uptime (s)",
      "gridPos": { "h": 7, "w": 4, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "time() - process_start_time_seconds{service=\"api\"}", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    }
  ]
}
