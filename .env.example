# ─── Application ──────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=wikipulse
POSTGRES_USER=wikipulse
POSTGRES_PASSWORD=wikipulse
DATABASE_URL=postgresql+psycopg://wikipulse:wikipulse@postgres:5432/wikipulse

# ─── Kafka ────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_RAW=wiki.raw
KAFKA_TOPIC_INDEX=wiki.index
KAFKA_TOPIC_ANALYTICS=wiki.analytics
KAFKA_TOPIC_VANDALISM=wiki.vandalism
KAFKA_TOPIC_DEADLETTER=wiki.deadletter
KAFKA_CONSUMER_GROUP=wikipulse

# ─── Elasticsearch ────────────────────────────────────────────
ELASTICSEARCH_URL=http://elasticsearch:9200
ES_LIVE_INDEX_PREFIX=wiki-live-events
ES_LIVE_READ_ALIAS=wiki-live-events-read
ES_LIVE_WRITE_ALIAS=wiki-live-events-write
LIVE_RETENTION_HOURS=24

# ─── Data Retention ───────────────────────────────────────────
HOURLY_RETENTION_DAYS=90
CONSOLIDATED_RETENTION_DAYS=365

# ─── Consolidation ────────────────────────────────────────────
CONSOLIDATION_WINDOW_HOURS=3
TZ_UTC_OFFSET=0

# ─── Wikimedia EventStreams source ────────────────────────────
WIKIMEDIA_STREAM_URL=https://stream.wikimedia.org/v2/stream/recentchange
WIKIMEDIA_EVENT_TYPES=edit,new,log
WIKIMEDIA_CONNECT_TIMEOUT=15

# ─── Streaming services ───────────────────────────────────────
# Producer is idempotent (librdkafka) and keys messages on language.
PRODUCER_IDEMPOTENT=true
INDEXER_BATCH_SIZE=100
INDEXER_FLUSH_INTERVAL_S=2.0
ANALYTICS_BATCH_SIZE=200
ANALYTICS_FLUSH_INTERVAL_S=2.0
VANDALISM_THRESHOLD=0.5
VANDALISM_BATCH_SIZE=200
CONSUMER_POLL_TIMEOUT=1.0
CONSUMER_AUTO_OFFSET_RESET=latest
CONSUMER_ENABLE_AUTO_COMMIT=false

# ─── Scheduler cadences (seconds) ─────────────────────────────
SCHEDULER_HOURLY_INTERVAL_S=60
SCHEDULER_RECONCILE_INTERVAL_S=120
SCHEDULER_CONSOLIDATE_INTERVAL_S=10800
SCHEDULER_CLEANUP_LIVE_INTERVAL_S=3600
SCHEDULER_CLEANUP_AGG_INTERVAL_S=86400
RECONCILE_HOURS=3

# ─── Live broadcast (dashboard WebSocket feed) ────────────────
LIVE_BROADCAST_ENABLED=true
LIVE_BROADCAST_GROUP=wikipulse-live
LIVE_BROADCAST_MAX_RATE_PER_S=50
